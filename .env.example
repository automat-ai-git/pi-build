# Anthropic API key (обязательно)
ANTHROPIC_API_KEY=sk-ant-...

# GID группы docker на хосте
# Проверить: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999

# Caddy — домен и авторизация (добавить в .env n8n-install)
PI_HOSTNAME=pi.твой-домен.com
PI_USERNAME=admin
# Сгенерировать хэш: docker exec caddy caddy hash-password --plaintext "ваш_пароль"
PI_PASSWORD_HASH=

# Plane MCP
PLANE_API_KEY=
PLANE_WORKSPACE_SLUG=
PLANE_BASE_URL=http://plane-app-api-1:8000
